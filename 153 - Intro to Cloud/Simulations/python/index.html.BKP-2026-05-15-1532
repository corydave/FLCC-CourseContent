<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Python Fundamentals</title>

  <!--
    ================================================================
    PYTHON FUNDAMENTALS — Interactive Lesson
    ================================================================
    A browser-based mini-course that teaches Python to beginners.

    The star feature: this uses PYODIDE — Python compiled to
    WebAssembly — so when you click "Run", actual Python code
    executes right here in your browser. No server needed!

    Structure of this file:
      1. <head>       — fonts and metadata
      2. <style>      — all CSS (light/dark mode, layout, components)
      3. <body>       — HTML skeleton (header, panes, footer)
      4. <script>     — lessons data + all application logic
    ================================================================
  -->

  <!-- Google Fonts: Display serif + accessible body + mono for code -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    /* ============================================================
       1. CSS CUSTOM PROPERTIES (Design Tokens)
       ------------------------------------------------------------
       We define every colour and font here once, using CSS
       variables (--name: value). Light and dark modes are handled
       by swapping the values when [data-theme="dark"] is set on
       the <html> element. This means we never have to write
       separate colour rules for dark mode further down.
       ============================================================ */

    :root {
      /* --- Page backgrounds --- */
      --bg-page:       #FBF7F0;   /* warm cream */
      --bg-pane:       #FFFFFF;   /* white card */
      --bg-code:       #1C1917;   /* very dark brown — code editor */
      --bg-output:     #F3EDE4;   /* slightly tinted — output / callout */
      --bg-header:     #231F1C;   /* near-black header */

      /* --- Text colours --- */
      --text-primary:  #2D2417;   /* dark brown body text */
      --text-secondary:#6B5B47;   /* muted secondary text */
      --text-code:     #F5EFE6;   /* warm white inside dark editor */
      --text-header:   #F5EFE6;   /* light text on dark header */

      /* --- Accent colours (Python's brand palette!) --- */
      --accent-orange: #E07B39;   /* Python orange */
      --accent-blue:   #3572A5;   /* Python blue */
      --accent-green:  #2A7A4A;   /* success */
      --accent-red:    #B83232;   /* error */

      /* --- Borders and shadows --- */
      --border:        #E8DDD0;
      --shadow:        0 2px 10px rgba(45,36,23,0.10);

      /* --- Typography --- */
      --font-body:     'Atkinson Hyperlegible', sans-serif;
      --font-display:  'DM Serif Display', serif;
      --font-mono:     'JetBrains Mono', monospace;

      /* --- Shape --- */
      --radius:        0.5rem;
    }

    /* Dark mode: only the colour tokens change — all other rules
       below stay exactly the same, which is why this approach is so powerful. */
    [data-theme="dark"] {
      --bg-page:       #1A1714;
      --bg-pane:       #231F1C;
      --bg-code:       #0F0E0C;
      --bg-output:     #1A1714;
      --bg-header:     #0F0E0C;

      --text-primary:  #F0EAE0;
      --text-secondary:#A89880;
      --text-code:     #F5EFE6;
      --text-header:   #F0EAE0;

      --accent-orange: #F0923A;
      --accent-blue:   #5AAEE8;
      --accent-green:  #3CB371;
      --accent-red:    #E05555;

      --border:        #3A3530;
      --shadow:        0 2px 10px rgba(0,0,0,0.40);
    }


    /* ============================================================
       2. RESET & BASE
       ============================================================ */

    *, *::before, *::after {
      box-sizing: border-box; /* padding doesn't add to width */
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      background: var(--bg-page);
      color: var(--text-primary);
      /* Flex column makes header + main + footer fill the viewport height */
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      transition: background 0.25s, color 0.25s;
    }


    /* ============================================================
       3. LOADING SCREEN
       ------------------------------------------------------------
       Pyodide (the Python runtime) takes a few seconds to download
       and initialise. We show this full-screen overlay while we wait.
       It's hidden once Python is ready.
       ============================================================ */

    #loading-screen {
      position: fixed;       /* covers everything */
      inset: 0;              /* top/right/bottom/left = 0 */
      background: var(--bg-page);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      z-index: 999;          /* above everything else */
      transition: opacity 0.4s;
    }

    #loading-screen.fade-out {
      opacity: 0;
      pointer-events: none;  /* don't block clicks while fading */
    }

    .loading-snake {
      font-size: 3rem;
      animation: bob 1.4s ease-in-out infinite;
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-8px); }
    }

    .loading-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--text-primary);
    }

    .loading-bar-track {
      width: 220px;
      height: 5px;
      background: var(--border);
      border-radius: 3px;
      overflow: hidden;
    }

    /* The pulsing bar — no real progress, just visual feedback */
    .loading-bar-fill {
      height: 100%;
      background: var(--accent-orange);
      border-radius: 3px;
      animation: pulse-bar 1.6s ease-in-out infinite;
    }

    @keyframes pulse-bar {
      0%   { width: 5%; }
      50%  { width: 80%; }
      100% { width: 5%; }
    }

    .loading-msg {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-secondary);
    }


    /* ============================================================
       4. HEADER
       ============================================================ */

    .site-header {
      background: var(--bg-header);
      color: var(--text-header);
      padding: 0.85rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      box-shadow: var(--shadow);
      position: sticky;    /* stays at top when you scroll */
      top: 0;
      z-index: 100;
      flex-shrink: 0;      /* never shrinks in the flex column */
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex: 1;
      min-width: 0;        /* lets flex children shrink below content width */
    }

    .site-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: normal; /* DM Serif Display is already bold-looking */
      white-space: nowrap;
    }

    /* Small orange "Part 1" badge */
    .part-badge {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      background: var(--accent-orange);
      color: #fff;
      padding: 0.2rem 0.55rem;
      border-radius: 0.3rem;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Progress bar sits inside the header on wide screens */
    .progress-wrapper {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex: 1;
      max-width: 280px;
    }

    .progress-track {
      flex: 1;
      height: 5px;
      background: rgba(255,255,255,0.12);
      border-radius: 3px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: var(--accent-orange);
      border-radius: 3px;
      width: 0%;
      transition: width 0.5s ease;
    }

    .progress-label {
      font-size: 0.72rem;
      opacity: 0.6;
      white-space: nowrap;
    }

    /* Dark/light mode toggle button */
    .theme-btn {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.18);
      color: var(--text-header);
      width: 2.1rem;
      height: 2.1rem;
      border-radius: 50%;
      cursor: pointer;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, border-color 0.2s;
      flex-shrink: 0;
    }

    .theme-btn:hover,
    .theme-btn:focus-visible {
      background: rgba(255,255,255,0.14);
      border-color: rgba(255,255,255,0.35);
      outline: none;
    }

    .theme-btn:focus-visible {
      outline: 2px solid var(--accent-orange);
      outline-offset: 2px;
    }


    /* ============================================================
       5. MAIN LAYOUT — two-column split panes
       ============================================================ */

    .main-layout {
      flex: 1;               /* takes up all remaining vertical space */
      display: grid;
      grid-template-columns: 1fr 1fr;  /* equal halves */
      min-height: 0;         /* lets grid children scroll independently */
    }

    /* Both panes scroll on their own */
    .pane {
      padding: 2rem;
      overflow-y: auto;
    }

    .instruction-pane {
      background: var(--bg-pane);
      border-right: 1px solid var(--border);
    }

    .interactive-pane {
      background: var(--bg-page);
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }


    /* ============================================================
       6. LESSON CONTENT TYPOGRAPHY
       (Everything rendered into .instruction-pane)
       ============================================================ */

    .lesson-meta {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--accent-orange);
      text-transform: uppercase;
      letter-spacing: 0.09em;
      margin-bottom: 0.5rem;
    }

    .lesson-title {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: normal;
      line-height: 1.15;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }

    /* Generic rich-text styles used inside lessons */
    .lesson-body p {
      line-height: 1.75;
      margin-bottom: 0.9rem;
      color: var(--text-primary);
    }

    .lesson-body h3 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: normal;
      margin: 1.5rem 0 0.4rem;
      color: var(--text-primary);
    }

    .lesson-body ul,
    .lesson-body ol {
      padding-left: 1.4rem;
      line-height: 2.2;
      margin-bottom: 0.9rem;
    }

    /* Inline code (inside a sentence) */
    .lesson-body code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      background: var(--bg-output);
      color: var(--accent-orange);
      padding: 0.15em 0.4em;
      border-radius: 0.25rem;
    }

    /* Code blocks (multi-line examples) */
    .lesson-body pre {
      background: var(--bg-code);
      color: var(--text-code);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.65;
      padding: 1rem 1.2rem;
      border-radius: var(--radius);
      overflow-x: auto;
      margin: 0.8rem 0;
    }

    /* Inside a pre, reset code to inherit (no coloured bg) */
    .lesson-body pre code {
      background: none;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }

    /* Orange left-border callout box */
    .callout {
      border-left: 3px solid var(--accent-orange);
      background: rgba(224, 123, 57, 0.08);
      padding: 0.8rem 1rem;
      border-radius: 0 var(--radius) var(--radius) 0;
      margin: 1rem 0;
      font-size: 0.92rem;
      line-height: 1.65;
    }

    /* Blue variant for warnings / important notes */
    .callout.note {
      border-color: var(--accent-blue);
      background: rgba(53, 114, 165, 0.08);
    }


    /* ============================================================
       7. INTERACTIVE PANE — editor, output, controls
       ============================================================ */

    /* Small uppercase label above each section */
    .field-label {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
    }

    /* The code editor textarea */
    .code-editor {
      width: 100%;
      background: var(--bg-code);
      color: var(--text-code);
      font-family: var(--font-mono);
      font-size: 0.875rem;
      line-height: 1.65;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      resize: vertical;       /* user can drag the bottom edge to resize */
      min-height: 160px;
      outline: none;
      tab-size: 4;            /* real tabs display as 4 spaces wide */
      caret-color: var(--accent-orange);  /* coloured cursor */
      transition: border-color 0.2s;
    }

    .code-editor:focus {
      border-color: var(--accent-orange);
    }

    /* Output area — like a terminal */
    .output-area {
      background: var(--bg-code);
      color: #86EFAC;          /* soft green — terminal feel */
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.65;
      padding: 0.9rem 1rem;
      border-radius: var(--radius);
      min-height: 72px;
      white-space: pre-wrap;   /* respect newlines from print() */
      border: 1px solid var(--border);
    }

    .output-area.empty {
      color: var(--text-secondary);
      font-style: italic;
    }

    /* Errors show in red */
    .output-area.has-error {
      color: #FCA5A5;
    }

    /* Feedback strip shown after clicking Check */
    .feedback {
      padding: 0.75rem 1rem;
      border-radius: var(--radius);
      font-size: 0.9rem;
      line-height: 1.6;
      display: none;           /* hidden by default */
    }

    .feedback.correct {
      display: block;
      background: rgba(42, 122, 74, 0.12);
      border: 1px solid var(--accent-green);
      color: var(--accent-green);
    }

    .feedback.incorrect {
      display: block;
      background: rgba(184, 50, 50, 0.09);
      border: 1px solid var(--accent-red);
      color: var(--accent-red);
    }

    /* Hint text below the buttons */
    .hint-text {
      font-size: 0.83rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .hint-text code {
      font-family: var(--font-mono);
      background: var(--bg-output);
      padding: 0.1em 0.3em;
      border-radius: 0.2rem;
      font-size: 0.9em;
    }


    /* ============================================================
       8. BUTTONS
       ============================================================ */

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.55rem 1.1rem;
      border: none;
      border-radius: var(--radius);
      font-family: var(--font-body);
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s, transform 0.1s;
    }

    .btn:active { transform: scale(0.97); }

    .btn:focus-visible {
      outline: 2px solid var(--accent-orange);
      outline-offset: 2px;
    }

    /* Run button — Python blue */
    .btn-run {
      background: var(--accent-blue);
      color: #fff;
      font-family: var(--font-mono);
    }
    .btn-run:hover:not(:disabled) { filter: brightness(1.12); }
    .btn-run:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Check button — orange */
    .btn-check {
      background: var(--accent-orange);
      color: #fff;
    }
    .btn-check:hover:not(:disabled) { filter: brightness(1.1); }
    .btn-check:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Next button — in footer */
    .btn-next {
      background: var(--accent-orange);
      color: #fff;
      padding: 0.6rem 1.5rem;
    }
    .btn-next:hover:not(:disabled) { filter: brightness(1.1); }
    .btn-next:disabled { opacity: 0.35; cursor: not-allowed; }

    /* Reset / secondary button */
    .btn-secondary {
      background: var(--bg-output);
      color: var(--text-primary);
      border: 1px solid var(--border);
    }
    .btn-secondary:hover { background: var(--border); }


    /* ============================================================
       9. FOOTER
       ============================================================ */

    .site-footer {
      background: var(--bg-pane);
      border-top: 1px solid var(--border);
      padding: 0.85rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-shrink: 0;
    }


    /* ============================================================
       10. COMPLETION SCREEN
       ============================================================ */

    .complete-screen {
      text-align: center;
      padding: 1.5rem 0;
    }

    .complete-emoji {
      font-size: 4rem;
      display: block;
      margin-bottom: 1rem;
    }

    .complete-title {
      font-family: var(--font-display);
      font-size: 2.2rem;
      color: var(--accent-orange);
      margin-bottom: 1rem;
    }

    .complete-body {
      font-size: 1rem;
      line-height: 1.8;
      color: var(--text-primary);
      max-width: 440px;
      margin: 0 auto 1.5rem;
    }

    .complete-date {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 2rem;
    }

    .next-steps-list {
      list-style: none;
      padding: 0;
      text-align: left;
      line-height: 2.4;
      font-size: 0.95rem;
    }

    .next-steps-list li::before {
      content: "→ ";
      color: var(--accent-orange);
      font-weight: bold;
    }


    /* ============================================================
       11. UTILITIES
       ============================================================ */

    .hidden { display: none !important; }

    /* "sr-only" content is invisible but readable by screen readers */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
    }


    /* ============================================================
       12. DEBUG PANEL
       ------------------------------------------------------------
       Only visible when ?debug=true is in the URL.
       Fixed to the bottom-right corner so it never overlaps content.
       ============================================================ */

    #debug-panel {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      background: var(--bg-pane);
      border: 1px solid var(--accent-orange);
      border-radius: var(--radius);
      padding: 0.75rem;
      box-shadow: var(--shadow);
      z-index: 200;
      max-width: 220px;
    }

    .debug-heading {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-orange);
      margin-bottom: 0.5rem;
    }

    /* Grid of small numbered buttons — one per lesson */
    .debug-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.3rem;
    }

    .debug-grid button {
      background: var(--bg-output);
      border: 1px solid var(--border);
      color: var(--text-primary);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      padding: 0.3rem 0;
      border-radius: 0.25rem;
      cursor: pointer;
      transition: background 0.15s;
    }

    .debug-grid button:hover {
      background: var(--accent-orange);
      color: #fff;
      border-color: var(--accent-orange);
    }

    /* Highlight the currently active lesson button */
    .debug-grid button.active {
      background: var(--accent-orange);
      color: #fff;
      border-color: var(--accent-orange);
    }


    /* ============================================================
       14. RESPONSIVE — stack panes on small screens
       ============================================================ */

    @media (max-width: 800px) {
      .main-layout {
        grid-template-columns: 1fr;   /* single column */
      }

      .instruction-pane {
        border-right: none;
        border-bottom: 1px solid var(--border);
      }

      /* Hide progress bar in header on small screens */
      .progress-wrapper { display: none; }

      .site-title { font-size: 1.1rem; }
      .pane { padding: 1.5rem; }
    }


    /* ============================================================
       15. REDUCED MOTION — respect user preference
       ============================================================ */

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>

  <!--
    ================================================================
    LOADING SCREEN
    ================================================================
    Shown while Pyodide (the Python WebAssembly runtime) downloads.
    The JS will hide this once Python is ready.
    ================================================================
  -->
  <div id="loading-screen" aria-live="polite" aria-label="Loading Python environment">
    <span class="loading-snake" role="img" aria-label="snake emoji">🐍</span>
    <p class="loading-title">Python Fundamentals</p>
    <div class="loading-bar-track" role="progressbar" aria-label="Loading progress">
      <div class="loading-bar-fill"></div>
    </div>
    <p class="loading-msg" id="loading-msg">Loading Python…</p>
  </div>


  <!--
    ================================================================
    HEADER
    ================================================================
  -->
  <header class="site-header">
    <div class="header-left">
      <h1 class="site-title">Python Fundamentals</h1>
      <span class="part-badge">Part 1</span>
      <div class="progress-wrapper" aria-label="Course progress">
        <div class="progress-track">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <span class="progress-label" id="progress-label" aria-live="polite">0 / 10</span>
      </div>
    </div>
    <button class="theme-btn" id="theme-btn" aria-label="Toggle dark mode">🌙</button>
  </header>


  <!--
    ================================================================
    MAIN — two-column layout
    ================================================================
    The instruction pane (left) holds lesson explanations.
    The interactive pane (right) holds the code editor and output.
    Both are filled by JavaScript.
    ================================================================
  -->
  <main class="main-layout" id="main-layout">
    <section class="pane instruction-pane" id="instruction-pane"
             aria-label="Lesson explanation">
      <!-- Filled by renderLesson() -->
    </section>

    <section class="pane interactive-pane" id="interactive-pane"
             aria-label="Code editor and output">
      <!-- Filled by renderLesson() -->
    </section>
  </main>


  <!--
    ================================================================
    FOOTER — navigation controls
    ================================================================
  -->
  <footer class="site-footer">
    <button class="btn btn-secondary hidden" id="btn-reset"
            aria-label="Reset code to starter template">↺ Reset</button>
    <button class="btn btn-next" id="btn-next" disabled
            aria-label="Go to next lesson">Next Lesson →</button>
  </footer>


  <!--
    ================================================================
    DEBUG PANEL
    ----------------------------------------------------------------
    Only rendered / made visible when the URL contains ?debug=true
    Lets developers jump straight to any lesson without clicking
    through them one by one. Very handy when editing lesson content.

    Usage:  open the file with  ?debug=true  in the URL, e.g.
            file:///path/to/python-fundamentals.html?debug=true

    You can also jump to a specific lesson directly:
            ?debug=true&lesson=5   (goes straight to lesson 5)
    ================================================================
  -->
  <aside id="debug-panel" class="hidden" aria-label="Debug: jump to lesson">
    <p class="debug-heading">🛠 Debug — jump to lesson</p>
    <div class="debug-grid" id="debug-grid">
      <!-- Buttons are built by JS so they can use LESSONS.length -->
    </div>
  </aside>


  <!--
    ----------------------------------------------------------------
    Pyodide is Python compiled to WebAssembly. It lets us run
    actual Python code inside the browser, with no server needed.
    The script tag makes loadPyodide() available globally.
    ================================================================
