            <p>Now let's combine them in one mini program.</p>
            <div class="callout">
              💡 <strong>Final challenge:</strong> Write a function called
              <code>summarise</code> that takes a list of numbers and prints:
              <ul>
                <li>The count of numbers</li>
                <li>Their total</li>
                <li>Whether the total is <code>Above 100</code> or <code>Below 100</code></li>
              </ul>
              Then call it with <code>[10, 20, 30, 25]</code>.
            </div>
          </div>
        `,

        starterCode:
`def summarise(numbers):
    count = len(numbers)
    total = sum(numbers)
    print(f"Count: {count}")
    print(f"Total: {total}")
    if total > 100:
        print("Above 100")
    else:
        print("Below 100")

summarise([10, 20, 30, 25])
`,

        validate(output, code) {
          const hasDef = /def\s+summarise\s*\(/.test(code);

          if (!hasDef) {
            return { correct: false, message: 'Define the function: def summarise(numbers):' };
          }

          const lines        = output.trim().split('\n').map(l => l.trim());
          const hasCount     = lines.some(l => l.toLowerCase().startsWith('count'));
          const hasTotal     = lines.some(l => l.toLowerCase().startsWith('total'));
          const hasAboveBelow= lines.some(l => l.includes('Above') || l.includes('Below'));

          if (hasCount && hasTotal && hasAboveBelow) {
            return { correct: true, message: '🎉 You did it! Python Fundamentals complete. You can write real programs now!' };
          }

          if (!hasCount)      return { correct: false, message: 'Print the count — e.g. print(f"Count: {count}")' };
          if (!hasTotal)      return { correct: false, message: 'Print the total — e.g. print(f"Total: {total}")' };
          if (!hasAboveBelow) return { correct: false, message: 'Use if/else to print "Above 100" or "Below 100".' };

          return { correct: false, message: 'Check that you print count, total, and the above/below comparison.' };
        },

        hint: 'The starter code is complete — run it and check to finish the course!'
      }

    ]; // end LESSONS array


    /* ================================================================
       B. APP STATE
       ----------------------------------------------------------------
       A single plain object holds everything that changes over time.
       This makes the app much easier to reason about — state is always
       in one place, not scattered across many variables.
       ================================================================ */

    const app = {
      currentIndex: 0,           // Which lesson we're on (0-based)
      pyodide:      null,        // Python runtime (set after loading)
      passed:       [],          // Boolean per lesson: has the user passed it?
    };


    /* ================================================================
       C. PYTHON RUNNER
       ----------------------------------------------------------------
       We use Pyodide — Python compiled to WebAssembly — so the code
       really executes. loadPython() downloads and initialises Pyodide
       once at startup. runPython() executes a code string and captures
       any print() output.
       ================================================================ */

    /**
     * Download and initialise Pyodide.
     * Hides the loading screen when done, then calls initApp().
     */
    async function loadPython() {
      const loadingMsg = document.getElementById('loading-msg');

      try {
        loadingMsg.textContent = 'Starting Python runtime…';

        /*
          loadPyodide() is a global function injected by the Pyodide
          <script> tag. We tell it where to fetch its WebAssembly files.
        */
        app.pyodide = await loadPyodide({
          indexURL: 'https://cdn.jsdelivr.net/pyodide/v0.25.0/full/'
        });

        loadingMsg.textContent = 'Python ready!';

        // Fade out the loading screen, then remove it from view
        const screen = document.getElementById('loading-screen');
        screen.classList.add('fade-out');

        // Wait for the CSS transition to finish before hiding
        setTimeout(() => {
          screen.classList.add('hidden');
          initApp();
        }, 450);

      } catch (err) {
        loadingMsg.textContent = '❌ Could not load Python. Please refresh.';
        console.error('Pyodide load error:', err);
      }
    }


    /**
     * Execute a string of Python code and return what was printed.
     *
     * @param {string} code   The Python source code to run
     * @returns {{ output: string, hasError: boolean }}
     */
    async function runPython(code) {
      let captured = '';     // We'll collect all print() output here
      let hasError  = false;

      /*
        Redirect Python's stdout (normal print output) and stderr
        (error messages) so they go into our 'captured' variable
        instead of the browser console.
      */
      app.pyodide.setStdout({ batched: text => { captured += text + '\n'; } });
      app.pyodide.setStderr({ batched: text => { captured += text + '\n'; hasError = true; } });

      try {
        // runPythonAsync handles async Pyodide operations correctly
        await app.pyodide.runPythonAsync(code);
      } catch (err) {
        // Python syntax errors and runtime errors land here
        captured = err.message;
        hasError = true;
      }

      // Remove trailing newline from the last print()
      return { output: captured.trimEnd(), hasError };
    }


    /* ================================================================
       D. RENDERER
       ----------------------------------------------------------------
       renderLesson() builds the HTML for a lesson and injects it
       into the two page panes.
       ================================================================ */

    /**
     * Render a lesson into the instruction and interactive panes.
     * @param {number} index  0-based lesson index
     */
    function renderLesson(index) {
      const lesson          = LESSONS[index];
      const instructionPane = document.getElementById('instruction-pane');
      const interactivePane = document.getElementById('interactive-pane');
      const btnNext         = document.getElementById('btn-next');
      const btnReset        = document.getElementById('btn-reset');

      document.title = `${lesson.title} — Python Fundamentals`;

      /* ── Left pane: lesson explanation ── */
      instructionPane.innerHTML = lesson.description;

      /* ── Right pane: editor + controls + output ── */
      interactivePane.innerHTML = `
        <div>
          <div class="field-label">editor.py</div>
          <textarea
            class="code-editor"
            id="code-editor"
            aria-label="Python code editor"
            spellcheck="false"
            autocorrect="off"
            autocapitalize="off"
          >${escapeHtml(lesson.starterCode)}</textarea>
        </div>

        <div style="display:flex; gap:0.6rem; align-items:flex-start; flex-wrap:wrap;">
          <button class="btn btn-run"   id="btn-run"   aria-label="Run your code">▶ Run</button>
          <button class="btn btn-check" id="btn-check" aria-label="Check your answer">✓ Check</button>
          <p class="hint-text" id="hint-area" style="margin-top:0.3rem;">${lesson.hint}</p>
        </div>

        <div>
          <div class="field-label">output</div>
          <div
            class="output-area empty"
            id="output-area"
            role="log"
            aria-live="polite"
            aria-label="Code output"
          >— click ▶ Run to see output —</div>
        </div>

        <div class="feedback" id="feedback-area" role="alert" aria-live="assertive"></div>
      `;

      /* ── Enable / disable Next based on whether already passed ── */
      btnNext.disabled = !app.passed[index];
      btnReset.classList.remove('hidden');

      /* ── Wire up the Tab key in the editor ── */
      document.getElementById('code-editor').addEventListener('keydown', handleEditorTab);

      /* ── Wire up Run button ── */
      document.getElementById('btn-run').addEventListener('click', runAndDisplay);

      /* ── Wire up Check button ── */
      document.getElementById('btn-check').addEventListener('click', checkAnswer);

      /* ── Wire up Reset button (in footer) ── */
      btnReset.onclick = () => {
        document.getElementById('code-editor').value = lesson.starterCode;
        const out = document.getElementById('output-area');
        out.textContent  = '— click ▶ Run to see output —';
        out.className    = 'output-area empty';
        document.getElementById('feedback-area').className = 'feedback';
        document.getElementById('feedback-area').textContent = '';
      };

      updateProgress();

      // Keep the debug panel in sync if it's active
      highlightDebugButton(index);
    }


    /* ================================================================
       E. VALIDATORS
       ----------------------------------------------------------------
       runAndDisplay() — executes code and shows output, no marking
       checkAnswer()   — executes code, validates, shows feedback
       ================================================================ */

    /**
     * Run the code in the editor and display the output.
     * Does NOT check whether the answer is right.
     */
    async function runAndDisplay() {
      const code      = document.getElementById('code-editor').value;
      const outputArea= document.getElementById('output-area');
      const runBtn    = document.getElementById('btn-run');

      // Show a loading state while Python executes
      runBtn.disabled    = true;
      runBtn.textContent = '⏳ Running…';
      outputArea.className = 'output-area';
      outputArea.textContent = '';

      const { output, hasError } = await runPython(code);

      outputArea.textContent = output || '(no output)';
      outputArea.className   = hasError ? 'output-area has-error' : 'output-area';

      runBtn.disabled    = false;
      runBtn.textContent = '▶ Run';
    }


    /**
     * Run the code AND validate it against the lesson's validate() function.
     * Shows a coloured feedback message and unlocks Next if correct.
     */
    async function checkAnswer() {
      const code        = document.getElementById('code-editor').value;
      const outputArea  = document.getElementById('output-area');
      const feedbackArea= document.getElementById('feedback-area');
      const checkBtn    = document.getElementById('btn-check');

      // Disable the button while processing
      checkBtn.disabled    = true;
      checkBtn.textContent = '⏳ Checking…';

      const { output, hasError } = await runPython(code);

      // Show the raw output
      outputArea.textContent = output || '(no output)';
      outputArea.className   = hasError ? 'output-area has-error' : 'output-area';

      // If Python threw an error, stop before calling validate()
      if (hasError) {
        feedbackArea.textContent = '⚠️ Your code has an error — fix it, then check again.';
        feedbackArea.className   = 'feedback incorrect';
        checkBtn.disabled        = false;
        checkBtn.textContent     = '✓ Check';
        return;
      }

      // Ask the lesson's validate function for the verdict
      const lesson = LESSONS[app.currentIndex];
      const result = lesson.validate(output, code);

      feedbackArea.textContent = result.message;
      feedbackArea.className   = result.correct ? 'feedback correct' : 'feedback incorrect';

      if (result.correct) {
        // Mark lesson as passed, unlock the Next button
        app.passed[app.currentIndex] = true;
        document.getElementById('btn-next').disabled = false;
        updateProgress();
      }

      checkBtn.disabled    = false;
      checkBtn.textContent = '✓ Check';
    }


    /* ================================================================
       F. NAVIGATION
       ================================================================ */

    /** Move to the next lesson, or show the completion screen. */
    function goNext() {
      if (app.currentIndex < LESSONS.length - 1) {
        app.currentIndex++;
        renderLesson(app.currentIndex);
        // Scroll both panes back to the top (helpful on mobile)
        document.getElementById('instruction-pane').scrollTop = 0;
        document.getElementById('interactive-pane').scrollTop = 0;
        window.scrollTo(0, 0);
      } else {
        showCompletion();
      }
    }


    /** Update the header progress bar and label. */
    function updateProgress() {
      const passedCount = app.passed.filter(Boolean).length;
      const total       = LESSONS.length;
      const pct         = (passedCount / total) * 100;

      document.getElementById('progress-fill').style.width = pct + '%';
      document.getElementById('progress-label').textContent = `${passedCount} / ${total}`;
    }


    /* ================================================================
       COMPLETION SCREEN
       Replaces both panes with a congratulations message and a list
       of suggested next steps.
       ================================================================ */

    function showCompletion() {
      const instructionPane = document.getElementById('instruction-pane');
      const interactivePane = document.getElementById('interactive-pane');
      const btnNext         = document.getElementById('btn-next');
      const btnReset        = document.getElementById('btn-reset');

      btnNext.classList.add('hidden');
      btnReset.classList.add('hidden');

      const today = new Date().toLocaleDateString('en-GB', {
        day: 'numeric', month: 'long', year: 'numeric'
      });

      instructionPane.innerHTML = `
        <div class="complete-screen">
          <span class="complete-emoji" role="img" aria-label="snake">🐍</span>
          <h2 class="complete-title">Python Fundamentals Complete!</h2>
          <p class="complete-body">
            You've finished <strong>Python Fundamentals Part 1</strong>.
            You can now write real Python programs — using variables, strings,
            numbers, lists, conditionals, loops, functions, and dictionaries.
            That's the foundation everything else is built on.
          </p>
          <p class="complete-date">Completed ${today}</p>
        </div>
      `;

      interactivePane.innerHTML = `
        <div>
          <h3 style="font-family:var(--font-display); font-size:1.4rem; font-weight:normal; margin-bottom:1rem;">
            What to learn next
          </h3>
          <ul class="next-steps-list">
            <li><strong>Modules &amp; imports</strong> — unlock Python's enormous library ecosystem</li>
            <li><strong>File reading &amp; writing</strong> — work with real data on disk</li>
            <li><strong>Error handling</strong> — try / except to catch mistakes gracefully</li>
            <li><strong>List comprehensions</strong> — Python's elegant shorthand for loops</li>
            <li><strong>Classes &amp; objects</strong> — object-oriented programming</li>
            <li><strong>Data science</strong> — pandas, numpy, and matplotlib</li>
            <li><strong>Web &amp; APIs</strong> — fetch data from the internet</li>
          </ul>
          <div class="callout" style="margin-top:1.5rem;">
            🎉 <strong>Well done!</strong> Python is one of the world's most
            popular programming languages — and now you know the fundamentals.
          </div>
        </div>
      `;
    }


    /* ================================================================
       G. THEME
       ----------------------------------------------------------------
       Light/dark mode. We store the preference in localStorage so it
       persists between visits.
       ================================================================ */

    function initTheme() {
      // Read saved preference, or fall back to the OS setting
      const saved      = localStorage.getItem('python-lesson-theme');
      const prefersDark= window.matchMedia('(prefers-color-scheme: dark)').matches;
      applyTheme(saved || (prefersDark ? 'dark' : 'light'));
    }

    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      document.getElementById('theme-btn').textContent = (theme === 'dark') ? '☀️' : '🌙';
      localStorage.setItem('python-lesson-theme', theme);
    }

    function toggleTheme() {
      const current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    }


    /* ================================================================
       H. UTILITIES
       ================================================================ */

    /**
     * Convert special HTML characters to safe entities.
     * This prevents code like <script> in the editor from being
     * interpreted as actual HTML.
     *
     * @param {string} text  Raw text
     * @returns {string}     Safe HTML string
     */
    function escapeHtml(text) {
      return text
        .replace(/&/g,  '&amp;')
        .replace(/</g,  '&lt;')
        .replace(/>/g,  '&gt;')
        .replace(/"/g,  '&quot;');
    }

    /**
     * Handle Tab key inside the code editor textarea.
     * By default, Tab moves keyboard focus away from the textarea.
     * We intercept it and insert 4 spaces at the cursor instead —
     * which is the standard Python indentation.
     *
     * @param {KeyboardEvent} event
     */
    function handleEditorTab(event) {
      if (event.key !== 'Tab') return;

      event.preventDefault(); // Stop Tab from jumping to the next element

      const textarea = event.target;
      const start    = textarea.selectionStart;
      const end      = textarea.selectionEnd;
      const SPACES   = '    '; // 4 spaces — Python's convention

      // Insert the spaces at the cursor position
      textarea.value =
        textarea.value.slice(0, start) + SPACES + textarea.value.slice(end);

      // Move the cursor to just after the inserted spaces
      textarea.selectionStart = textarea.selectionEnd = start + 4;
    }


    /* ================================================================
       I. DEBUG MODE
       ----------------------------------------------------------------
       Activated by adding ?debug=true to the URL.
       Shows a floating panel of numbered buttons so you can jump to
       any lesson instantly — no need to click through from lesson 1.

       You can also pre-select a lesson with ?debug=true&lesson=5
       (lesson numbers are 1-based to match what humans see).
       ================================================================ */

    /**
     * Check the URL for ?debug=true and set up the panel if found.
     * Called once inside initApp().
     */
    function initDebugMode() {
      // URLSearchParams reads query string key/value pairs safely
      const params   = new URLSearchParams(window.location.search);
      const isDebug  = params.get('debug') === 'true';

      if (!isDebug) return; // Nothing to do in normal mode

      /* ── Show the panel ── */
      const panel = document.getElementById('debug-panel');
      panel.classList.remove('hidden');

      /* ── Build one button per lesson ── */
      const grid = document.getElementById('debug-grid');

      LESSONS.forEach((lesson, index) => {
        const btn = document.createElement('button');

        // Label is 1-based ("1" through "10") so it matches the lesson meta text
        btn.textContent = index + 1;
        btn.title       = lesson.title;  // tooltip on hover
        btn.setAttribute('aria-label', `Jump to lesson ${index + 1}: ${lesson.title}`);

        btn.addEventListener('click', () => {
          // Mark all lessons up to (but not including) this one as passed,
          // so the Next button is enabled and the progress bar looks right.
          for (let i = 0; i < index; i++) {
            app.passed[i] = true;
          }

          app.currentIndex = index;
          renderLesson(index);
          updateProgress();
          highlightDebugButton(index);

          // Scroll panes to top after jumping
          document.getElementById('instruction-pane').scrollTop = 0;
          document.getElementById('interactive-pane').scrollTop = 0;
        });

        grid.appendChild(btn);
      });

      /* ── Handle ?lesson=N to jump straight to a lesson on load ── */
      const lessonParam = parseInt(params.get('lesson'), 10);

      if (!isNaN(lessonParam) && lessonParam >= 1 && lessonParam <= LESSONS.length) {
        // Convert 1-based URL param to 0-based index
        const targetIndex = lessonParam - 1;

        // Mark all previous lessons as passed so navigation works
        for (let i = 0; i < targetIndex; i++) {
          app.passed[i] = true;
        }

        app.currentIndex = targetIndex;
        renderLesson(targetIndex);
        updateProgress();
        highlightDebugButton(targetIndex);
      } else {
        // Default: highlight button 1
        highlightDebugButton(0);
      }
    }

    /**
     * Update which debug button appears "active" (orange).
     * @param {number} index  0-based lesson index
     */
    function highlightDebugButton(index) {
      const grid = document.getElementById('debug-grid');
      if (!grid) return;

      // Remove active class from all buttons, then add to the right one
      Array.from(grid.querySelectorAll('button')).forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });
    }


    /* ================================================================
       J. STARTUP
       ----------------------------------------------------------------
       initApp() is called once Pyodide has loaded successfully.
       loadPython() kicks everything off when the DOM is ready.
       ================================================================ */

    /** Set up the app once Pyodide is loaded. */
    function initApp() {
      // Initialise the passed array: one false per lesson
      app.passed = new Array(LESSONS.length).fill(false);

      // Apply theme before first render (prevents flash)
      initTheme();

      // Wire up UI controls
      document.getElementById('theme-btn').addEventListener('click', toggleTheme);
      document.getElementById('btn-next').addEventListener('click', goNext);

      // Render the first lesson (debug mode may override this below)
      renderLesson(0);
      updateProgress();

      // Set up debug panel — reads URL params, does nothing if not ?debug=true
      initDebugMode();
    }

    // Start loading Python as soon as the DOM is ready
    window.addEventListener('DOMContentLoaded', loadPython);

  </script>
</body>
</html>